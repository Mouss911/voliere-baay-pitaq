# Console Firebase → Paramètres du projet → Vos applications → Config SDK
# Déploiement Vercel : copier ces clés dans Project → Settings → Environment Variables
# (Production + Preview). Pas de guillemets, pas d'espace avant/après. Redeploy après ajout.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Cloudinary → Dashboard → Paramètres du compte (cloud name)
# Upload preset : Settings → Upload → Add upload preset → Signing mode = Unsigned
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
